# Windows Agent ローカル設定
# このファイルを agent_config.yaml にコピーして編集してください

# OBSファイル整理（Sub PCのみ）
obs_file_organizer:
  enabled: true
  host: "localhost"
  port: 4455
  password: ""  # OBS WebSocket パスワード
  timeout: 10
  connect_retry_interval_seconds: 10
  output_base_dir: "V:/tdarr/incoming"
  encoded_base_dir: "V:/tdarr/encoded"
  unknown_folder: "Unknown"
  screenshot_folder: "_screenshot"
  file_move_retries: 3
  file_move_retry_delay_seconds: 1
  cleanup_interval_seconds: 3600

# Main PC Agent 情報（Sub PCがゲーム名を問い合わせる先）
windows_agents:
  - host: "192.168.1.210"
    port: 7777
    role: main

# STT（音声テキスト化）
# Main PC: マイクキャプチャ + Sub PCへバッチ送信
# Sub PC: Whisperモデルで推論
stt:
  enabled: false
  # Main PC用設定
  capture:
    device: null  # マイクデバイスID（nullでデフォルト、WebGUIから変更可能）
    vad_aggressiveness: 2  # 0-3（3が最も厳しい）
    volume_threshold_rms: 300
    silence_threshold_seconds: 1.5
    min_utterance_seconds: 1.0
  sub_pc_url: "http://192.168.1.211:7777"
  batch:
    interval_minutes: 5
  # Sub PC用設定
  model:
    name: "kotoba-tech/kotoba-whisper-v2.0"
    device: "cuda"
    torch_dtype: "float16"
    unload_after_minutes: 10
