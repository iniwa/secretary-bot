# Windows Agent ローカル設定
# このファイルを agent_config.yaml にコピーして編集してください

# OBSファイル整理（Sub PCのみ）
obs_file_organizer:
  enabled: true
  host: "localhost"
  port: 4455
  password: ""  # OBS WebSocket パスワード
  timeout: 10
  connect_retry_interval_seconds: 10
  output_base_dir: "V:/tdarr/incoming"
  encoded_base_dir: "V:/tdarr/encoded"
  unknown_folder: "Unknown"
  screenshot_folder: "_screenshot"
  file_move_retries: 3
  file_move_retry_delay_seconds: 1
  cleanup_interval_seconds: 3600

# Main PC Agent 情報（Sub PCがゲーム名を問い合わせる先）
windows_agents:
  - host: "192.168.1.210"
    port: 7777
    role: main

# STT（音声テキスト化）
# Main PC: マイクキャプチャ + Sub PCへバッチ送信
# Sub PC: Whisperモデルで推論
stt:
  enabled: false
  # Main PC用設定
  capture:
    device: null  # マイクデバイスID（nullでデフォルト、WebGUIから変更可能）
    vad_aggressiveness: 2  # 0-3（3が最も厳しい）
    volume_threshold_rms: 300
    silence_threshold_seconds: 1.5
    min_utterance_seconds: 1.0
    # ハルシネーション抑制: 発話区間のVAD=True比率がこの値未満なら破棄（0.0-1.0）
    voiced_ratio_threshold: 0.5
    # ハルシネーション抑制: 連続Nフレーム有声で発話開始とみなす（30ms/フレーム）
    speech_start_consecutive: 3
  sub_pc_url: "http://192.168.1.211:7777"
  batch:
    interval_minutes: 5
  # Sub PC用設定
  model:
    name: "kotoba-tech/kotoba-whisper-v2.0"
    device: "cuda"
    torch_dtype: "float16"
    unload_after_minutes: 10

# 画像生成（ComfyUI / kohya）
# Main/Sub 両方に導入する方針。ComfyUI をローカル起動し、
# 成果物は NAS（SMB マウント）経由で Pi と共有する。
image_gen:
  enabled: true
  root: "C:/secretary-bot"                  # SECRETARY_BOT_ROOT 相当（ComfyUI/kohya インストール先）
  cache: "C:/secretary-bot-cache"           # SECRETARY_BOT_CACHE 相当（モデルキャッシュ）
  comfyui:
    host: "0.0.0.0"                         # WebGUI の ComfyUI リンクを LAN 越しに開く場合は 0.0.0.0。LAN 内限定運用を前提
    port: 8188
    startup_timeout_seconds: 60
    health_check_interval_seconds: 30
    crash_restart_max_retries: 3
  kohya:
    enabled: true                           # Main/Sub 両方導入方針。使わない PC は false
  cache_lru:
    max_size_gb: 100                        # ローカル SSD キャッシュ上限
  nas:
    host: ""                                # NAS SMB ホスト（.env の NAS_HOST で上書き推奨）
    share: "ai-image"                       # SMB 共有名。専用共有が無い場合は親共有名にし subpath を指定
    subpath: ""                             # 共有内のベースサブパス（例: 既存 Work 共有を流用 → share:"Work"/subpath:"ai-image"）
    mount_drive: "N:"                       # Windows 側マウントドライブレター
