{
  "_meta": {
    "description": "t2i 多重LoRA（キャラ + 絵柄 + 構図 の3段チェーン）。スロット2/3 は強度0で実質無効、UIで有効化",
    "category": "t2i",
    "main_pc_only": false,
    "default_timeout_sec": 300
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG}}",
      "sampler_name": "{{SAMPLER}}",
      "scheduler": "{{SCHEDULER}}",
      "denoise": 1.0,
      "model": ["12", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{CKPT}}"
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{POSITIVE}}",
      "clip": ["12", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE}}",
      "clip": ["12", 1]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["4", 2]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "{{FILENAME_PREFIX}}",
      "images": ["8", 0]
    }
  },
  "10": {
    "class_type": "LoraLoader",
    "_meta": {"title": "Character LoRA"},
    "inputs": {
      "lora_name": "INIWA_NOOBXL.safetensors",
      "strength_model": 0.45,
      "strength_clip": 0.9,
      "model": ["4", 0],
      "clip": ["4", 1]
    }
  },
  "11": {
    "class_type": "LoraLoader",
    "_meta": {"title": "Style LoRA"},
    "inputs": {
      "lora_name": "INIWA_NOOBXL.safetensors",
      "strength_model": 0.0,
      "strength_clip": 0.0,
      "model": ["10", 0],
      "clip": ["10", 1]
    }
  },
  "12": {
    "class_type": "LoraLoader",
    "_meta": {"title": "Composition LoRA"},
    "inputs": {
      "lora_name": "INIWA_NOOBXL.safetensors",
      "strength_model": 0.0,
      "strength_clip": 0.0,
      "model": ["11", 0],
      "clip": ["11", 1]
    }
  }
}
