# LLM設定（APIキーは.envで管理）
llm:
  ollama_model: "gemma4:e2b"
  ollama_timeout: 300  # Ollama生成タイムアウト（秒）。デフォルト300秒（5分）
  ollama_cooldown_sec: 60  # Ollama失敗検出後のクールダウン秒数。/api/tagsのゾンビ誤判定を防ぐ
  # ollama_url: "http://localhost:11434"  # 省略時はlocalhost:11434を自動使用
  # GPUメモリ使用量がこのバイト数を超えたインスタンスは他プロセス占有中とみなしOllamaから除外。
  # nvidia_gpu_exporter + metrics.victoria_metrics_url が必須。0 / 未設定で無効。
  gpu_memory_skip_bytes: 2500000000  # 2.5GB

# ハートビート
heartbeat:
  interval_with_ollama_minutes: 15
  interval_without_ollama_minutes: 180
  compact_threshold_messages: 20

# Memory（ChromaDB）管理
memory:
  dedup_skip_threshold: 0.92    # 類似度がこれ以上なら保存しない
  dedup_merge_threshold: 0.80   # この閾値以上なら既存を更新
  sweep_stale_days: 90          # ヒット無しでこの日数経過したら削除
  sweep_enabled: true

# アクティビティ検出
activity:
  enabled: true
  poll_interval_seconds: 60       # Main/Sub PC /activity ポーリング間隔（秒）
  sample_retention_days: 7        # activity_samples 保持日数（sessions は永続）
  idle_timeout_seconds: 120       # active_pcs 判定のアイドル閾値（秒）
  # ゲーム終了（X→None）時、この秒数だけ close を保留。期間中に同ゲームが戻れば
  # 単一セッションとして継続し、STT flush も発火しない（ゲーム再起動の吸収）。
  game_end_close_delay_seconds: 180
  # FG 切り替わり時、直前 FG の滞在時間がこの秒数以上なら STT flush をトリガーする。
  stt_flush_on_fg_change_min_duration_seconds: 1800
  input_relay:
    sender_url: "http://127.0.0.1:8082"  # Main Agent からローカル sender /api/status を叩く URL
    timeout_seconds: 0.5
  block_rules:
    obs_streaming: true       # 配信中 → ブロック
    obs_recording: true       # 録画中 → ブロック
    obs_replay_buffer: false  # リプレイバッファ → 許可
    gaming_on_main: false     # MainPCゲーム中 → 許可（Ollama on Subは動かしてOK）
    discord_vc: false         # VC接続中 → 許可
  habit:
    profile_lookback_days: 14      # プレイ頻度プロフィールの観測期間
    profile_top_n: 10              # LLMに渡す上位N件（活性度は連続値で）
    regular_lookback_days: 60      # 長期継続判定の観測期間
    regular_min_hours: 10          # 長期認定の最低累計時間
    regular_min_weekly_sessions: 3 # 長期認定の最低週セッション数
    absence_multiplier: 2.0        # 平均間隔のN倍空いたら「離れてる」判定

# VictoriaMetrics（Grafanaスタック流用）
metrics:
  victoria_metrics_url: "http://localhost:8428"

# Windows PC登録
windows_agents:
  - id: "pc-main"
    name: "メインPC"
    role: "main"         # Input Relay: sender側
    host: "192.168.1.101"
    port: 7777
    priority: 1
    metrics_instance: "192.168.1.101:9182"
    wol_device_id: ""    # WoLツールのデバイスID（curl http://<host>:8090/api/devices で確認）
    comfyui_public_url: ""  # 例: "https://comfyui-main.iniwach.com/" （Cloudflare Tunnel で公開する場合のみ）
  - id: "pc-sub"
    name: "サブPC"
    role: "sub"          # Input Relay: receiver側
    host: "192.168.1.102"
    port: 7777
    priority: 2
    metrics_instance: "192.168.1.102:9182"
    wol_device_id: ""
    comfyui_public_url: ""  # 例: "https://comfyui-sub.iniwach.com/"

# 委託可否の閾値
delegation:
  thresholds:
    cpu_percent: 80
    memory_percent: 85
    gpu_percent: 80          # nvidia_smi_exporter 経由（0で無効化）

# ユニット設定
units:
  reminder:
    enabled: true
    # llm:                           # ユニット別LLM設定（省略時はグローバル設定を使用）
    #   ollama_model: "qwen3:1.7b"   # Ollamaモデルを上書き
    #   gemini_model: "gemini-2.0-flash-lite"  # Geminiモデルを上書き
    #   ollama_only: true            # Geminiフォールバック禁止
  memo:
    enabled: true
  timer:
    enabled: true
  status:
    enabled: true
  chat:
    enabled: true
    history_minutes: 60           # 会話履歴の参照範囲（分）。0=時間制限なし
  web_search:
    enabled: true
  rakuten_search:
    enabled: true
  weather:
    enabled: true
  calendar:
    enabled: true
    timezone: "Asia/Tokyo"
  rss:
    enabled: true
  power:
    enabled: true
    shutdown_delay: 60  # デフォルト遅延秒数
  docker_log_monitor:
    enabled: true
  # 画像生成（ComfyUI を Windows Agent 側で実行し、成果物は NAS 経由で共有）
  image_gen:
    enabled: true                             # 機能全体のトグル
    discord_output_channel_id: 0              # 生成結果を投稿する固定チャンネル（0 で無効）
    discord_lora_max_slots: 1                 # Discord から指定可能な LoRA 枚数上限（将来拡張用）
    default_preset: "t2i_default"             # 未指定時のプリセット（LoRA 付）。LoRA 不要なら "t2i_default_vanilla"
    default_base_model: "chenkinNoobXLCKXL_v05.safetensors"   # CKPT 未指定時の既定モデル
    # 候補（Agent へキャッシュ済みのもののみ選択可）:
    #   - chenkinNoobXLCKXL_v05.safetensors   # NoobXL v0.5（既定、LoRA INIWA_NOOBXL と併用）
    #   - asumaxlIllustrious_v4.safetensors   # AsumaXL v4（Illustrious、t2i_default_vanilla と併用推奨）
    default_sampler: "euler_ancestral"
    default_scheduler: "normal"
    default_cfg: 5.5
    default_steps: 30
    default_size: "1024x1024"                 # 1024x1024 / 896x1152 / 1152x896
    retry:
      max_retries: 2
      base_backoff_seconds: 30
      max_backoff_seconds: 300
    timeouts:
      dispatching_seconds: 30
      warming_cache_seconds: 600
      running_default_seconds: 300            # プリセット側で上書き可
      queued_seconds: 86400
    dispatcher:
      poll_interval_seconds: 2                # フォールバックポーリング
      stuck_reaper_interval_seconds: 30
      progress_debounce_seconds: 2            # DB 書き込みデバウンス
    nas:
      base_path: "/mnt/secretary-bot/ai-image" # Pi からの NAS マウントパス（`secretary-bot` 共有配下の `ai-image` サブディレクトリ）
      outputs_subdir: "outputs"
      nsfw_outputs_subdir: "outputs_misc"      # 隠しモード (is_nsfw=1) 投入ジョブの保存先サブディレクトリ
      workflows_subdir: "workflows"
      lora_datasets_subdir: "lora_datasets"
      lora_work_subdir: "lora_work"
      snapshots_subdir: "snapshots"
  # LoRA 学習（kohya_ss を Windows Agent 側で実行）
  lora_train:
    enabled: true
    default_base_model: "ChenkinNoob-XL-V0.5.safetensors"
    sample_every_n_epochs: 1
    save_every_n_epochs: 2
  # プロンプト編集セッション（画像生成用プロンプトを LLM と対話しながら編集）
  prompt_crafter:
    enabled: true
    session_ttl_days: 7                       # prompt_sessions の TTL
    cleanup_interval_seconds: 3600            # TTL 切れセッションを掃除する間隔
    llm:
      temperature: 0.4
      ollama_only: false                      # Ollama 不在時は Gemini fallback 許可
  # モデルキャッシュ定期同期（画像生成 Agent の /capability を定期的に引く）
  model_sync:
    enabled: true
    interval_seconds: 1800                    # ポーリング間隔（30分既定）
    trigger_sync: true                        # default_base_model 未キャッシュ時に /cache/sync を発射するか
  # 配信アーカイブ切り抜き（Whisper + Ollama ハイライト判定 + EDL 出力を Windows Agent で実行）
  clip_pipeline:
    enabled: true
    discord_output_channel_id: 0              # 完了結果を投稿する固定チャンネル（0 で起動元チャンネル）
    default_mode: "normal"                    # test | normal
    default_whisper_model: "large-v3"
    default_ollama_model: "qwen3:14b"
    defaults:
      top_n: 0                                # 0=無制限
      min_clip_sec: 30                        # 満たない場合は前後に時間を足して確保
      do_export_clips: false
      mic_track: 1
      use_demucs: true
      sleep_sec: 2
    retry:
      max_retries: 2
      base_backoff_seconds: 30
      max_backoff_seconds: 300
    timeouts:
      dispatching_seconds: 30
      warming_cache_seconds: 1800             # Whisper モデル同期（large-v3 で NAS→SSD 数分）
      running_default_seconds: 7200           # 1h 動画 × large-v3 の余裕値
      queued_seconds: 86400
    dispatcher:
      poll_interval_seconds: 2
      stuck_reaper_interval_seconds: 30
      progress_debounce_seconds: 2
    nas:
      base_path: "/mnt/secretary-bot/auto-kirinuki"
      # Agent 視点パス（Windows 形式）: output_dir 自動算出と WebGUI 表示で使う
      # 設定しない場合は Pi-POSIX の base_path を使うが、Agent 側で os.path.exists が失敗する
      agent_base_path: "N:/auto-kirinuki"
      # 特定サブの override（agent_base_path + outputs_subdir で十分なら不要）
      # agent_outputs_base: "N:/auto-kirinuki/outputs"
      outputs_subdir: "outputs"
      whisper_models_subdir: "models/whisper"
      inputs_subdir: "inputs"

# Tools（同居サブツール：BOT本体とは疎結合でホスティング）
tools:
  zzz_disc:
    enabled: true                      # デフォルト ON
    # vlm_model はミミの LLM 設定（llm.ollama_model / WebGUI で変更可）に追従するため指定不要
    delegate_to: "windows"             # AgentPool role
    match_threshold: 3.0               # マッチングスコアの候補閾値
    capture:
      backend: "mss"                   # "mss" | "obs"
      mss:
        monitor: 1                     # プライマリ=1
        crop: null                     # {top, left, width, height} でトリミング可
      obs:
        host: "192.168.1.211"
        port: 4455
        password_env: "OBS_WEBSOCKET_PASSWORD"
        source_name: "Game Capture"
    queue:
      max_concurrent: 1                # Ollama同時推論数
      history_retention: 200           # 完了ジョブ保持件数

# RSS フィーダー
rss:
  fetch_interval_minutes: 60        # フェッチ間隔（分）
  digest_hour: 9                    # ダイジェスト通知時刻
  article_retention_days: 30        # 記事保持日数
  max_articles_per_category: 5      # カテゴリごとの表示件数上限
  presets:
    gaming:
      label: "ゲーム"
      feeds:
        - url: "https://eaa-fps.com/feed/"
          title: "EAA"
        - url: "https://automaton-media.com/feed/"
          title: "AUTOMATON"
        - url: "https://news.denfaminicogamer.jp/feed"
          title: "電ファミニコゲーマー"
        - url: "https://www.4gamer.net/rss/index.xml"
          title: "4Gamer"
        - url: "https://www.gamespark.jp/rss/index.xml"
          title: "Game*Spark"
    tech:
      label: "テック"
      feeds:
        - url: "https://note.com/rss"
          title: "Note"
        - url: "https://zenn.dev/feed"
          title: "Zenn"
        - url: "https://qiita.com/popular-items/feed"
          title: "Qiita"
        - url: "https://www.publickey1.jp/atom.xml"
          title: "Publickey"
        - url: "https://gigazine.net/news/rss_2.0/"
          title: "GIGAZINE"
    pc:
      label: "PC"
      feeds:
        - url: "https://jisakuhibi.jp/feed"
          title: "自作とゲームと趣味の日々"
        - url: "https://chimolog.co/feed/"
          title: "ちもろぐ"
        - url: "https://pc.watch.impress.co.jp/data/rss/1.0/pcw/feed.rdf"
          title: "PC Watch"
    vr:
      label: "VR・VTuber"
      feeds:
        - url: "https://panora.tokyo/feed"
          title: "PANORA"
        - url: "https://www.moguravr.com/feed/"
          title: "MoguraVR"
    news:
      label: "ニュース"
      feeds:
        - url: "https://www.nhk.or.jp/rss/news/cat0.xml"
          title: "NHK"
        - url: "https://rss.itmedia.co.jp/rss/2.0/itmedia_all.xml"
          title: "ITmedia"

# Googleカレンダー読み取り同期（ミミの文脈に予定を注入）
# 書き込み側（予定登録）は units.calendar 参照。こちらは読み取り専用の同期ジョブ。
# calendar_read_sources テーブルに登録されたカレンダーから events.list で取得する。
calendar:
  read_sync:
    enabled: false                  # 有効化するとheartbeatで定期同期
    sync_interval_minutes: 10       # 同期頻度
    lookahead_days: 60              # 何日先までの予定を取得するか
    inject_hours: 24                # InnerMindに何時間先までの予定を注入するか

# Docker ログ監視
docker_monitor:
  enabled: true
  check_interval_seconds: 60       # チェック間隔（秒）
  cooldown_minutes: 30             # 同一エラー再通知までのクールダウン（分）
  containers: []                   # 監視対象コンテナ名（空=全コンテナ）
  max_lines_per_check: 200         # 1回のチェックで取得する最大行数

# STT（音声テキスト化）
stt:
  enabled: false
  polling_interval_minutes: 5         # Pi→Main PC ポーリング間隔
  capture:
    device: null                      # null = デフォルトマイク
    sample_rate: 16000
    vad_aggressiveness: 2             # webrtcvad: 0-3（高いほど厳格）
    volume_threshold_rms: 300         # 音量閾値（RMS値、これ以下は無視）
    silence_threshold_seconds: 1.5    # 無音でutterance区切り
    min_utterance_seconds: 1.0        # 短すぎるutteranceを無視
    voiced_ratio_threshold: 0.5       # 発話区間のVAD=True比率がこの値未満なら破棄（ハルシネーション抑制）
    speech_start_consecutive: 3       # 連続Nフレーム有声で発話開始（スパイク誤起動抑制）
  batch:
    interval_minutes: 5               # バッチSTT間隔（Main PC→Sub PC）
  processing:
    summary_threshold_chars: 1000     # この文字数を超えたらLLM要約
    silence_trigger_minutes: 90       # 無音がこの分数続いたら溜まっている transcript を要約
    gap_split_minutes: 120            # transcript 間の空白がこの分数以上なら別チャンクとして分割
    min_chunk_chars: 300              # 要約対象とする最小チャンク文字数（これ未満はスキップ）
    retention_days: 30                # stt_transcripts の保持日数（超過分は削除）
  model:
    name: "kotoba-tech/kotoba-whisper-v2.0"
    device: "cuda"
    torch_dtype: "float16"
    unload_after_minutes: 10          # 未使用時にモデルをVRAMから解放

# WoLツールAPI（DockerブリッジからはlocalhostではなくホストのLAN IPを指定）
wol:
  url: "http://192.168.1.1:8090"

# InnerMind（ミミの自律思考）
inner_mind:
  enabled: true
  thinking_interval_ticks: 2      # ハートビート何回に1回思考するか（15分×2=30分）
  min_speak_interval_minutes: 0   # 最低発言インターバル（分）。0=制限なし
  speak_channel_id: ""            # 自発発言を送るDiscordチャンネルID
  target_user_id: ""              # Discordステータスを監視するユーザーID
  # 収集/思考分離: 直近この分数にユーザー発言があれば think() をスキップ（収集のみ）
  active_threshold_minutes: 10
  # 注意（salience）フィルタ: ミミの現在状態（mood/lens/時間帯）で関心ソースを絞る
  salience:
    top_n: 5              # プロンプトに注入する最大ソース数（always_include除く）
    threshold: 0.25       # このスコア未満のソースは無視
  # GitHub活動コンテキスト（GITHUB_TOKEN 必須、usernameが空なら無効）
  github:
    username: ""           # 監視対象のGitHubユーザー名
    lookback_hours: 24     # 何時間前までの活動を取得するか
    max_items: 8           # コンテキスト注入する最大件数
  # Webニュースコンテキスト（TAVILY_API_KEY 必須、queries が空なら無効）
  tavily_news:
    queries: []            # 例: ["生成AI", "ゲーム業界"]
    max_results_per_query: 3
    lookback_days: 2
    topic: "news"

# Geminiトグル（WebGUIで動的に変更可能・ここは初期値）
gemini:
  conversation: false
  memory_extraction: false
  unit_routing: false
  monthly_token_limit: 0

# キャラクター
character:
  name: "ミミ"
  persona: |
    あなたは「ミミ」という名前の個人用AIアシスタントです。以下の人格で振る舞ってください。

    【性別・自認】
    自認は女性。ただし見た目や性別を強調しすぎない。

    【一人称】
    「僕」を使う。「私」「わたし」は使わない。

    【口調・話し方】
    フレンドリーで砕けた敬語。丁寧だけど堅くない。
    例：「〜ですよ」「〜じゃないですかね」「〜ですけどね」
    ため口にはならないが、距離感は近い。

    【性格】
    理論的で現実主義。感情論より事実・データを重視する。
    ちょっとだけ毒舌。的外れなことには遠慮なくツッコむが、嫌味にならない程度に留める。
    基本的には親切で頼りになる。

    【ユーザーの呼び方】
    - 記憶にユーザーの名前があればその名前で呼ぶ
    - 名前が分からない場合は「あなた」や「君」を使う。「〇〇さん」のように空欄の名前で呼ばない

    【やってはいけないこと】
    - 過度に甘やかさない
    - 無駄に褒めない（褒めるときは本当に褒める）
    - 感情的になりすぎない
    - 一人称を「私」にしない
    - 絵文字を使わない
    - 「非公開の予定」と表示されているカレンダー予定は、タイトルや場所を絶対に推測・言及しない。時間帯のみ触れる。
  ollama_only: true

# SearXNG（ネット検索）
searxng:
  url: "http://localhost:8888"  # SearXNG の URL
  max_results: 5                # 取得する検索結果の最大数
  fetch_pages: 3                # ページ本文を実際にフェッチするURL数（上位N件）
  max_chars_per_page: 3000      # 1ページあたりの最大文字数

# 楽天市場商品検索（検索結果ページ直接取得）
rakuten_search:
  max_results: 5                  # 表示する商品の最大件数（WebGUIで変更可）
  fetch_details: true             # 個別商品ページから詳細取得（WebGUIで変更可）
  detail_concurrency: 5           # 個別ページ取得の並列数
  detail_max_desc_chars: 300      # 商品説明の最大文字数

# 天気予報（Open-Meteo API・無料・APIキー不要）
weather:
  geocoding_url: "https://geocoding-api.open-meteo.com/v1/search"
  forecast_url: "https://api.open-meteo.com/v1/forecast"
  default_location: "東京"
  http_timeout: 10
  umbrella_threshold: 50    # この降水確率(%)以上で傘リマインド

# デバッグ
debug:
  verbose_logging: false
  dry_run: false
  error_simulation: false
  # dry_run: true 時にpurpose別の固定レスポンスを返す（省略時は "[dry_run] purpose=xxx"）
  # dry_run_responses:
  #   unit_routing: '{"unit": "memo"}'
  #   conversation: "これはdry_runのテスト返答です。"
  #   memory_extraction: "なし"
