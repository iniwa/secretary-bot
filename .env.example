# === LLM ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Discord ===
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_ADMIN_CHANNEL_ID=123456789012345678

# === WebGUI ===
WEBGUI_USERNAME=admin
WEBGUI_PASSWORD=your-password-here
WEBGUI_PORT=8100
WEBGUI_USER_ID=123456789012345678

# === Portainer ===
PORTAINER_URL=http://192.168.1.1:9000
PORTAINER_API_TOKEN=your-portainer-api-token-here
PORTAINER_ENV_ID=1
CONTAINER_NAME=secretary-bot

# === Gitea (コード更新機能で使用) ===
GITEA_URL=http://192.168.1.10:3000
GITEA_USER=your-gitea-username
GITEA_TOKEN=your-gitea-access-token

# === Google Calendar ===
GOOGLE_SERVICE_ACCOUNT_FILE=/app/data/service_account.json

# === Windows Agent ===
AGENT_SECRET_TOKEN=your-shared-secret-here

# === InnerMind ContextSources (optional) ===
# GitHub活動を inner_mind に注入する場合のみ設定
GITHUB_TOKEN=
# Webニュース(Tavily)を inner_mind に注入する場合のみ設定
TAVILY_API_KEY=

# === Image Generation (NAS) ===
# Pi から NAS を SMB マウントして画像生成成果物/LoRA データセットを共有
NAS_SMB_HOST=192.168.1.20            # NAS の IP/ホスト名
NAS_SMB_SHARE=ai-image               # 共有名
NAS_SMB_USER=your-nas-username       # 認証ユーザー
NAS_SMB_PASSWORD=your-nas-password   # パスワード
NAS_MOUNT_POINT=/mnt/ai-image        # Pi 側のマウント先
